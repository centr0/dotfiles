alias vim='nvim'

alias venv='venv.sh && source .venv/bin/activate'

alias ..='cd ..'

alias gs='git status'
alias ga='git add .'
alias gd='git ls-files --deleted | xargs -r git rm'
alias gc='git commit'
alias gl='git log --pretty="%H %s"'
alias gp='git push'
alias gf='git difftool'
alias gr='cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"'

alias cwd='pwd | tr -d "\n" | wl-copy'
alias cfn='basename "$PWD" | tr -d "\n" | wl-copy'

alias code='code --reuse-window'

alias chwp='wallpaper-shuffle.sh'

alias fd='cd "$(find $HOME -type d | fzf --preview="tree -d -C {}")"'

alias fh='cd "$(find . -type d | fzf --preview="tree -d -C {}")"'

alias gtf='nvim $(fzf -m --preview="bat --color=always {}")'
alias slsl='systemctl --user status hypridle.service hyprpaper.service hyprsunset.service mako.service waybar.service hyprpolkitagent.service'
